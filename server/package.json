{
  "name": "@sirene/server",
  "version": "0.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target bun --minify",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "bun --watch run src/index.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.9.48",
    "hono": "^4.7.11",
    "jszip": "^3.10.1",
    "pocketbase": "^0.26.5",
    "@sirene/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}